generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SprintStatus {
  PLANNED
  IN_PROGRESS
  DONE
}

enum CardType {
  EPIC
  STORY
  TASK
  SUB_TASK
  BUG
}

enum CardPriority {
  LOW
  MEDIUM
  HIGH
}

model Users {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @db.Timestamptz(3)
  deletedAt DateTime? @db.Timestamptz(3)

  name  String
  email String @unique

  assignedCards Cards[] @relation("CardAssignee")
  reportedCards Cards[] @relation("CardReporter")
}

model Sprints {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @db.Timestamptz(3)
  deletedAt DateTime? @db.Timestamptz(3)

  title     String
  status    SprintStatus @default(PLANNED)
  startDate DateTime?    @db.Timestamptz(3)
  endDate   DateTime?    @db.Timestamptz(3)
  goal      String?

  cards Cards[]
}

model Workflows {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @db.Timestamptz(3)
  deletedAt DateTime? @db.Timestamptz(3)

  title String
  order Int

  cards Cards[]
}

model Cards {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @db.Timestamptz(3)
  deletedAt DateTime? @db.Timestamptz(3)

  workflowId  Int
  sprintId    Int?
  assigneeId  Int?
  reporterId  Int?
  parentId    Int?
  key         String       @unique
  type        CardType     @default(TASK)
  title       String
  description String?
  order       Int
  dueDate     DateTime?    @db.Timestamptz(3)
  priority    CardPriority @default(MEDIUM)
  storyPoint  Int?

  workflow Workflows @relation(fields: [workflowId], references: [id], onDelete: Restrict)
  sprint   Sprints?  @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  assignee Users?    @relation("CardAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter Users?    @relation("CardReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  parent   Cards?    @relation("CardToCard", fields: [parentId], references: [id], onDelete: SetNull)
  children Cards[]   @relation("CardToCard")

  labels Labels[]

  @@index([workflowId])
  @@index([sprintId])
  @@index([assigneeId])
  @@index([reporterId])
  @@index([parentId])
}

model Labels {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @db.Timestamptz(3)
  deletedAt DateTime? @db.Timestamptz(3)

  name  String @unique
  color String

  cards Cards[]
}
